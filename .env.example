# Copy to .env and fill in values

# PostgreSQL (must match docker-compose.yml db service)
POSTGRES_DB=busybeaver
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# IANA timezone name — must match the server/user's local timezone
# Examples: America/Chicago, America/New_York, Europe/London, Asia/Tokyo
TIME_ZONE=America/Chicago

# Google Calendar OAuth
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:8000/auth/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/

# Base URL used when building feedback form links in calendar event descriptions
BASE_URL=http://localhost:8000
